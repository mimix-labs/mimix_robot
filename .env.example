# Desarrollo local: no guardar secretos reales en este archivo.
MIMIX_ROBOT_ID=robot-dev-001
MIMIX_MQTT_HOST=localhost
MIMIX_MQTT_PORT=1883
MIMIX_TOPIC_PREFIX=mimix/v1
MIMIX_OFFLINE_DB=data/mimix_robot.db

# Vision nativa de la Jetson. El servicio publica landmarks, no video.
MIMIX_VISION_API_URL=http://127.0.0.1:4000/api/vision/hand-landmarks
MIMIX_CAMERA_INDEX=0
MIMIX_CAMERA_WIDTH=640
MIMIX_CAMERA_HEIGHT=480
MIMIX_VISION_FPS=15
MIMIX_VIDEO_BIND_HOST=127.0.0.1
MIMIX_VIDEO_PORT=8081
MIMIX_VIDEO_FPS=10
MIMIX_VIDEO_JPEG_QUALITY=70
# Para una camara CSI, configurar el pipeline GStreamer en .env.
# MIMIX_CAMERA_PIPELINE=nvarguscamerasrc ! video/x-raw(memory:NVMM),width=640,height=480,framerate=30/1 ! nvvidconv ! video/x-raw,format=BGRx ! videoconvert ! video/x-raw,format=BGR ! appsink drop=true sync=false
